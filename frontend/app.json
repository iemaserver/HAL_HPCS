{
  "expo": {
    "name": "HAL Helicopter Performance",
    "slug": "hal-hpcs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hal-hpcs",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.hal.hpcs",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "navigationBar": {
        "backgroundColor": "#0F172A",
        "barStyle": "light-content"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logos/hal-logo.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#B8E4F5"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow HAL Helicopter Performance to use the microphone for voice input.",
          "speechRecognitionPermission": "Allow HAL Helicopter Performance to use speech recognition for voice input."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
